# ── Required ──
# MongoDB connection string (Atlas, or local: mongodb://localhost:27017/letter-platform)
MONGODB_URI=mongodb://localhost:27017/letter-platform

# App URL (used for shareable links / QR)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin auth (Clerk) — STRONGLY recommended ──
# Without these, the app still runs but /admin and the admin APIs are UNPROTECTED
# (a warning is logged). Get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ── Media uploads (Cloudinary) — optional ──
# Cloud name is public; the API key/secret enable SIGNED uploads (preferred — the
# secret never reaches the browser). An unsigned preset is a fallback only.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Optional unsigned fallback (less safe — public preset):
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
